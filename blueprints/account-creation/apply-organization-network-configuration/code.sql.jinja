-- ============================================================================
-- APPLY ORGANIZATION NETWORK CONFIGURATION
-- ============================================================================
-- Account: {{ new_account_name | upper }}
-- Using replicated network rules from: {{ platform_database_name | upper }}.{{ governance_name | upper }}
-- ============================================================================
-- EXECUTE FROM: New Account ({{ new_account_name | upper }})
-- REQUIRED ROLE: ACCOUNTADMIN
-- ============================================================================

USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- STEP 1: VERIFY ACCESS TO REPLICATED NETWORK RULES
-- ============================================================================

-- List network rules available from the replicated database
SHOW NETWORK RULES IN SCHEMA {{ platform_database_name | upper }}.{{ governance_name | upper }};

-- ============================================================================
-- STEP 2: CREATE NETWORK POLICY REFERENCING REPLICATED RULES
-- ============================================================================

CREATE OR REPLACE NETWORK POLICY {{ new_account_name | upper }}_NETWORK_POLICY
  ALLOWED_NETWORK_RULE_LIST = (
{%- for rule in allowed_network_rules %}
    {{ platform_database_name | upper }}.{{ governance_name | upper }}.{{ rule.rule_name | upper }}{% if not loop.last %},{% endif %}

{%- endfor %}
  )
{%- if blocked_network_rules | length > 0 %}
  BLOCKED_NETWORK_RULE_LIST = (
{%- for rule in blocked_network_rules %}
    {{ platform_database_name | upper }}.{{ governance_name | upper }}.{{ rule.rule_name | upper }}{% if not loop.last %},{% endif %}

{%- endfor %}
  )
{%- endif %}
  COMMENT = 'Network policy using organization-standard network rules';

-- ============================================================================
-- STEP 3: APPLY NETWORK POLICY TO ACCOUNT
-- ============================================================================

-- Apply the network policy to this account
ALTER ACCOUNT SET NETWORK_POLICY = {{ new_account_name | upper }}_NETWORK_POLICY;

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Verify the policy was created
SHOW NETWORK POLICIES LIKE '{{ new_account_name | upper }}_NETWORK_POLICY';

-- Verify account-level policy is set
SHOW PARAMETERS LIKE 'NETWORK_POLICY' IN ACCOUNT;

-- ============================================================================
-- IMPORTANT: TEST YOUR ACCESS
-- ============================================================================

