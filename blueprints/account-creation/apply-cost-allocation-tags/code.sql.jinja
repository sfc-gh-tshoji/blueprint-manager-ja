-- ============================================================================
-- APPLY COST ALLOCATION TAGS
-- ============================================================================
-- Account: {{ new_account_name | upper }}
-- Strategy: {{ account_strategy }}
{%- if account_strategy == 'Multi-Account (Domain-based)' %}
-- Domain: {{ account_domain }}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
-- Environment: {{ account_environment }}
{%- else %}
-- Domain: {{ account_domain }}
-- Environment: {{ account_environment }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: New Account ({{ new_account_name | upper }})
-- REQUIRED ROLE: ACCOUNTADMIN
-- ============================================================================

USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- STEP 1: VERIFY ACCESS TO SHARED TAGS
-- ============================================================================

-- Verify the shared infrastructure database is accessible
SHOW DATABASES LIKE '{{ shared_database_name | upper }}';

-- Verify tags are available
SHOW TAGS IN SCHEMA {{ shared_database_name | upper }}.{{ governance_name | upper }};

{%- if account_strategy == 'Multi-Account (Domain-based)' %}

-- Describe the DOMAIN tag
DESCRIBE TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.DOMAIN;

{%- elif account_strategy == 'Multi-Account (Environment-based)' %}

-- Describe the ENVIRONMENT tag
DESCRIBE TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.ENVIRONMENT;

{%- else %}

-- Describe both tags
DESCRIBE TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.DOMAIN;
DESCRIBE TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.ENVIRONMENT;

{%- endif %}

-- ============================================================================
-- STEP 2: CREATE SAMPLE WAREHOUSE FOR DEMONSTRATION
-- ============================================================================

-- Create a sample warehouse to demonstrate tagging
CREATE WAREHOUSE IF NOT EXISTS {{ new_account_name | upper }}_WH
  WAREHOUSE_SIZE = 'X-SMALL'
  AUTO_SUSPEND = 60
  AUTO_RESUME = TRUE
  INITIALLY_SUSPENDED = TRUE
  COMMENT = 'Default warehouse for {{ new_account_name }} account';

-- ============================================================================
-- STEP 3: APPLY APPROPRIATE TAG(S) TO THE WAREHOUSE
-- ============================================================================

{%- if account_strategy == 'Multi-Account (Domain-based)' %}

-- Apply DOMAIN tag (Environment will be applied at database level in Data Product workflow)
ALTER WAREHOUSE {{ new_account_name | upper }}_WH 
  SET TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.DOMAIN = '{{ account_domain }}';

{%- elif account_strategy == 'Multi-Account (Environment-based)' %}

-- Apply ENVIRONMENT tag (Domain will be applied at database level in Data Product workflow)
ALTER WAREHOUSE {{ new_account_name | upper }}_WH 
  SET TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.ENVIRONMENT = '{{ account_environment }}';

{%- else %}

-- Apply both DOMAIN and ENVIRONMENT tags
ALTER WAREHOUSE {{ new_account_name | upper }}_WH 
  SET TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.DOMAIN = '{{ account_domain }}';

ALTER WAREHOUSE {{ new_account_name | upper }}_WH 
  SET TAG {{ shared_database_name | upper }}.{{ governance_name | upper }}.ENVIRONMENT = '{{ account_environment }}';

{%- endif %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Verify tags were applied to the warehouse
SELECT 
  OBJECT_NAME,
  TAG_NAME,
  TAG_VALUE
FROM TABLE(INFORMATION_SCHEMA.TAG_REFERENCES('{{ new_account_name | upper }}_WH', 'WAREHOUSE'));

-- ============================================================================
-- TEMPLATE FOR FUTURE RESOURCES
-- ============================================================================

