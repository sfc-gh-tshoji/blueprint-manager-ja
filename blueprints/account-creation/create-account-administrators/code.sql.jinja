-- ============================================================================
-- CREATE/CONFIGURE ACCOUNT ADMINISTRATORS
-- ============================================================================
-- Account: {{ new_account_name | upper }}
-- Identity Provider: {{ identity_provider }}
-- ============================================================================
-- EXECUTE FROM: New Account ({{ new_account_name | upper }})
-- REQUIRED ROLE: ACCOUNTADMIN (or SECURITYADMIN for role grants)
-- ============================================================================

USE ROLE ACCOUNTADMIN;

{%- if identity_provider == "None - Manual User Management" %}

-- ============================================================================
-- CREATE ADMINISTRATOR USERS (Manual Mode)
-- ============================================================================
-- Creating local users since SCIM is not configured

{%- for user in account_admin_users %}

{# Determine if identifier needs quoting (contains @ or .) #}
{%- set identifier = user.user_identifier | default(user.login_name) %}
{%- set needs_quoting = '@' in identifier or '.' in identifier %}
{%- if needs_quoting %}
{%- set quoted_id = '"' ~ identifier ~ '"' %}
{%- else %}
{%- set quoted_id = identifier | upper %}
{%- endif %}

-- Create user: {{ identifier }}
CREATE USER IF NOT EXISTS {{ quoted_id }}
  LOGIN_NAME = '{{ user.login_name }}'
{%- if user.email %}
  EMAIL = '{{ user.email }}'
{%- endif %}
{%- if user.first_name %}
  FIRST_NAME = '{{ user.first_name }}'
{%- endif %}
{%- if user.last_name %}
  LAST_NAME = '{{ user.last_name }}'
{%- endif %}
  -- ⚠️  Replace <REPLACE_WITH_SECURE_PASSWORD> with a strong, unique password before executing.
  --    Min 14 chars, 1+ uppercase, 1+ lowercase, 1+ digit, 1+ special character.
  PASSWORD = '<REPLACE_WITH_SECURE_PASSWORD>'
  MUST_CHANGE_PASSWORD = TRUE
  COMMENT = 'Administrator user - {{ user.admin_role | upper }}';

{%- endfor %}

{%- endif %}

-- ============================================================================
-- ASSIGN ADMIN ROLES
-- ============================================================================

{%- for user in account_admin_users %}

{# Use same identifier logic #}
{%- set identifier = user.user_identifier | default(user.login_name) %}
{%- set needs_quoting = '@' in identifier or '.' in identifier %}
{%- if needs_quoting %}
{%- set quoted_id = '"' ~ identifier ~ '"' %}
{%- else %}
{%- set quoted_id = identifier | upper %}
{%- endif %}

-- Grant {{ user.admin_role | upper }} to {{ identifier }}
GRANT ROLE {{ user.admin_role | upper }} TO USER {{ quoted_id }};

{%- endfor %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- List all users
SHOW USERS;

-- Verify role grants
{%- for user in account_admin_users %}
{%- set identifier = user.user_identifier | default(user.login_name) %}
{%- set needs_quoting = '@' in identifier or '.' in identifier %}
{%- if needs_quoting %}
{%- set quoted_id = '"' ~ identifier ~ '"' %}
{%- else %}
{%- set quoted_id = identifier | upper %}
{%- endif %}
SHOW GRANTS TO USER {{ quoted_id }};
{%- endfor %}

-- ============================================================================
-- ADMINISTRATOR SETUP COMPLETE
-- ============================================================================

/*
Account Administrators Configured!
==================================

The following administrator roles have been assigned:

{%- for user in account_admin_users %}
- {{ user.login_name }}: {{ user.admin_role | upper }}
{%- endfor %}

{%- if identity_provider == "None - Manual User Management" %}

⚠️  Users have been created with temporary passwords.
   Each user must log in and change their password.
   Recommend enabling MFA after first login.

{%- else %}

Users were provisioned via SCIM from {{ identity_provider }}.
Admin roles have been assigned to their existing accounts.

{%- endif %}
*/