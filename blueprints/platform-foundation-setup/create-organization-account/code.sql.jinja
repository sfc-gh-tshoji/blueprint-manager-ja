-- ============================================================================
-- CREATE ORGANIZATION ACCOUNT
-- ============================================================================
-- This script creates the Organization Account with the specified configuration
-- Run this from your current (initial) account with ORGADMIN privileges
-- ============================================================================

-- ============================================================================
-- VERIFY ORGADMIN PRIVILEGES
-- ============================================================================
-- Before creating an Organization Account, verify you have ORGADMIN privileges

USE ROLE ORGADMIN;

-- Check current organization
SELECT CURRENT_ORGANIZATION_NAME() AS organization_name;

-- List existing accounts in the organization
SHOW ORGANIZATION ACCOUNTS;

-- ============================================================================
-- CREATE ORGANIZATION ACCOUNT
-- ============================================================================
-- ⚠️  IMPORTANT: Replace <REPLACE_WITH_SECURE_PASSWORD> with a strong, unique
--    password before executing. The user will be required to change this
--    password on first login (MUST_CHANGE_PASSWORD = TRUE).
--    Password requirements: min 14 chars, 1+ uppercase, 1+ lowercase,
--    1+ digit, 1+ special character.
--    Do NOT use a shared or reused password. Use a password manager to
--    generate and store it.
-- ============================================================================

CREATE ORGANIZATION ACCOUNT {{ org_account_name | upper }}
  ADMIN_NAME = '{{ org_admin_name }}'
  ADMIN_PASSWORD = '<REPLACE_WITH_SECURE_PASSWORD>'
  ADMIN_USER_TYPE = PERSON
  EMAIL = '{{ org_admin_email }}'
  MUST_CHANGE_PASSWORD = TRUE
  EDITION = {{ org_account_edition | upper }}
  REGION = '{{ org_account_region }}'
  COMMENT = 'Organization Account for centralized management';

-- ============================================================================
-- VERIFY ACCOUNT CREATION
-- ============================================================================

-- List accounts to verify the new Organization Account was created
SHOW ORGANIZATION ACCOUNTS;

-- View details of the new account
SELECT * FROM SNOWFLAKE.ORGANIZATION_USAGE.ACCOUNTS 
WHERE ACCOUNT_NAME = '{{ org_account_name | upper }}';

/*
============================================================================
NEXT STEPS
============================================================================
1. The initial administrator ({{ org_admin_name }}) will receive an email 
   with login credentials
2. Log into the new Organization Account at:
   https://{{ snowflake_org_name | upper }}-{{ org_account_name | upper }}.snowflakecomputing.com
3. Change the initial password on first login
4. Set up MFA for the ACCOUNTADMIN user
5. Add 1-2 additional ACCOUNTADMIN users for redundancy
6. Continue the remaining workflow steps in the Organization Account
============================================================================
*/