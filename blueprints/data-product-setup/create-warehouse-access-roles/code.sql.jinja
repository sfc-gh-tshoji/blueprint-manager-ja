-- ============================================================================
-- CREATE WAREHOUSE ACCESS ROLES
-- ============================================================================
-- Data Product: {{ data_product_name }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: SECURITYADMIN (to create and grant roles)
-- ============================================================================

-- Derive the data product prefix for object names
{%- if account_strategy == 'Single Account' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set prefix = data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set prefix = data_product_name | upper %}
{%- endif %}

USE ROLE SECURITYADMIN;

-- ============================================================================
-- CREATE WAREHOUSE ACCESS ROLES
-- ============================================================================
{% for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}
{%- set access_role = prefix ~ '_WH_U_' ~ wh.name | upper %}

-- ----------------------------------------------------------------------------
-- ACCESS ROLE: {{ access_role }}
-- For warehouse: {{ wh_name }}
-- ----------------------------------------------------------------------------

-- Create access role
CREATE ROLE IF NOT EXISTS {{ access_role }}
  COMMENT = 'Usage access to {{ wh_name }} warehouse';

-- Grant warehouse privileges
GRANT USAGE ON WAREHOUSE {{ wh_name }} TO ROLE {{ access_role }};
GRANT MONITOR ON WAREHOUSE {{ wh_name }} TO ROLE {{ access_role }};
GRANT OPERATE ON WAREHOUSE {{ wh_name }} TO ROLE {{ access_role }};

-- Transfer ownership to RBAC role for delegated administration
GRANT OWNERSHIP ON ROLE {{ access_role }} TO ROLE {{ prefix }}_RBAC COPY CURRENT GRANTS;

{% endfor %}

-- ============================================================================
-- GRANT ACCESS ROLES TO CORE ROLES
-- ============================================================================
-- All core roles get access to all warehouses by default
-- This can be customized based on requirements

{% for wh in warehouse_configuration %}
{%- set access_role = prefix ~ '_WH_U_' ~ wh.name | upper %}

-- Grant {{ access_role }} to core roles
GRANT ROLE {{ access_role }} TO ROLE {{ prefix }}_READ;
GRANT ROLE {{ access_role }} TO ROLE {{ prefix }}_WRITE;
GRANT ROLE {{ access_role }} TO ROLE {{ prefix }}_CREATE;
GRANT ROLE {{ access_role }} TO ROLE {{ prefix }}_ADMIN;

{% endfor %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show all warehouse access roles
SHOW ROLES LIKE '{{ prefix }}_WH_U_%';

-- Verify grants
{% for wh in warehouse_configuration %}
{%- set access_role = prefix ~ '_WH_U_' ~ wh.name | upper %}
SHOW GRANTS TO ROLE {{ access_role }};
{% endfor %}

/*
WAREHOUSE ACCESS ROLES CREATED
==============================

Created {{ warehouse_configuration | length }} warehouse access role(s):

{%- for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}
{%- set access_role = prefix ~ '_WH_U_' ~ wh.name | upper %}
  {{ loop.index }}. {{ access_role }}
     - USAGE on {{ wh_name }}
     - MONITOR on {{ wh_name }}
     - OPERATE on {{ wh_name }}
{%- endfor %}

All access roles granted to core roles (READ, WRITE, CREATE, ADMIN).

Ownership: {{ prefix }}_RBAC

NEXT STEPS:
- Step 3.3: Transfer ownership and wire hierarchy
*/
