-- ============================================================================
-- ASSIGN MONITORS TO WAREHOUSES
-- ============================================================================
-- Data Product: {{ data_product_name }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: ACCOUNTADMIN (to assign resource monitors)
-- ============================================================================

-- Derive the data product prefix for object names
{%- if account_strategy == 'Single Account' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set prefix = data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set prefix = data_product_name | upper %}
{%- endif %}

-- Resource monitor assignments require ACCOUNTADMIN
USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- ASSIGN RESOURCE MONITOR TO WAREHOUSES
-- ============================================================================
{% for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}

-- Assign monitor to {{ wh_name }}
ALTER WAREHOUSE {{ wh_name }} SET RESOURCE_MONITOR = {{ prefix }}_MONITOR;

{% endfor %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show all warehouses with their resource monitors
SHOW WAREHOUSES LIKE '{{ prefix }}_WH_%';

-- Verify monitor assignments
SELECT 
    "name" AS warehouse_name,
    "resource_monitor" AS assigned_monitor,
    "size" AS warehouse_size,
    "state" AS warehouse_state
FROM TABLE(RESULT_SCAN(LAST_QUERY_ID()))
WHERE "resource_monitor" = '{{ prefix }}_MONITOR';

-- Check monitor status
SHOW RESOURCE MONITORS LIKE '{{ prefix }}_MONITOR';

/*
MONITORS ASSIGNED
=================

Resource Monitor: {{ prefix }}_MONITOR

Assigned to warehouses:
{%- for wh in warehouse_configuration %}
  - {{ prefix }}_WH_{{ wh.name | upper }}
{%- endfor %}

Total warehouses: {{ warehouse_configuration | length }}

All warehouse credits will count toward the {{ resource_monitor_credits }} credit quota.

NEXT STEPS:
- Step 5.3: Configure alert notifications
- Monitor usage in ACCOUNT_USAGE.RESOURCE_MONITORS
*/
