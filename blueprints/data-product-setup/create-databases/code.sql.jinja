-- ============================================================================
-- CREATE DATABASES
-- ============================================================================
-- Data Product: {{ data_product_name }}
-- Zones: {% for zone in data_zones %}{{ zone.name | upper }}{% if not loop.last %}, {% endif %}{% endfor %}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: SYSADMIN (for database creation)
-- ============================================================================

-- Derive the data product prefix for object names
{%- if account_strategy == 'Single Account' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set prefix = data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set prefix = data_product_name | upper %}
{%- endif %}

-- Tag references
{%- set dp_domain_tag = platform_database_name | upper ~ '.' ~ governance_name | upper ~ '.DOMAIN' %}
{%- set dp_env_tag = platform_database_name | upper ~ '.' ~ governance_name | upper ~ '.ENVIRONMENT' %}
{%- set dp_product_tag = platform_database_name | upper ~ '.' ~ governance_name | upper ~ '.DATAPRODUCT' %}
{%- set dp_zone_tag = platform_database_name | upper ~ '.' ~ governance_name | upper ~ '.ZONE' %}

-- ============================================================================
-- CREATE DATABASES FOR EACH ZONE
-- ============================================================================
{% for zone in data_zones %}
{%- set db_name = prefix ~ '_' ~ zone.name | upper %}

-- ----------------------------------------------------------------------------
-- DATABASE: {{ db_name }}
-- Zone: {{ zone.name | upper }}
-- Time Travel: {{ zone.time_travel_days }} days
-- ----------------------------------------------------------------------------

-- Step 1: Create database as SYSADMIN
USE ROLE SYSADMIN;

CREATE DATABASE IF NOT EXISTS {{ db_name }}
  DATA_RETENTION_TIME_IN_DAYS = {{ zone.time_travel_days }}
  WITH TAG (
    {{ dp_domain_tag }} = '{{ data_product_domain | upper }}',
    {{ dp_env_tag }} = '{{ data_product_environment | upper }}',
    {{ dp_product_tag }} = '{{ data_product_name | upper }}',
    {{ dp_zone_tag }} = '{{ zone.name | upper }}'
  )
  COMMENT = '{{ data_product_name }} data product - {{ zone.name | upper }} zone ({{ zone.description }})';

-- Remove default PUBLIC schema (not needed)
DROP SCHEMA IF EXISTS {{ db_name }}.PUBLIC;

-- Step 2: Transfer ownership to delegated admin
GRANT OWNERSHIP ON DATABASE {{ db_name }} TO ROLE {{ prefix }}_ADMIN COPY CURRENT GRANTS;

-- Step 3: Create database-level access roles (as database owner)
USE ROLE {{ prefix }}_ADMIN;
USE DATABASE {{ db_name }};

-- Database Read Role
CREATE DATABASE ROLE IF NOT EXISTS DB_R
  COMMENT = 'Database read access for {{ db_name }}';

-- Database Write Role  
CREATE DATABASE ROLE IF NOT EXISTS DB_W
  COMMENT = 'Database write access for {{ db_name }}';

-- Database Create Role
CREATE DATABASE ROLE IF NOT EXISTS DB_C
  COMMENT = 'Database create access for {{ db_name }}';

-- Step 4: Transfer database role ownership to RBAC role
-- Note: Database role hierarchy (DB_C ← DB_W ← DB_R) is NOT established here.
-- Inheritance is handled at the schema level (SC_C ← SC_W ← SC_R), which then
-- rolls up to the database roles, avoiding redundant privilege chains.
GRANT OWNERSHIP ON DATABASE ROLE DB_R TO ROLE {{ prefix }}_RBAC COPY CURRENT GRANTS;
GRANT OWNERSHIP ON DATABASE ROLE DB_W TO ROLE {{ prefix }}_RBAC COPY CURRENT GRANTS;
GRANT OWNERSHIP ON DATABASE ROLE DB_C TO ROLE {{ prefix }}_RBAC COPY CURRENT GRANTS;

-- Step 5: Grant database roles to account roles
-- This connects account-level roles to database-level access
GRANT DATABASE ROLE DB_R TO ROLE {{ prefix }}_READ;
GRANT DATABASE ROLE DB_W TO ROLE {{ prefix }}_WRITE;
GRANT DATABASE ROLE DB_C TO ROLE {{ prefix }}_CREATE;

{% endfor %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show created databases
SHOW DATABASES LIKE '%{{ prefix }}%';

-- Show database roles for each database
{% for zone in data_zones %}
{%- set db_name = prefix ~ '_' ~ zone.name | upper %}
SHOW DATABASE ROLES IN DATABASE {{ db_name }};
{% endfor %}

-- Verify database role grants
{% for zone in data_zones %}
{%- set db_name = prefix ~ '_' ~ zone.name | upper %}
SELECT 
  '{{ db_name }}' AS database_name,
  grantee_name,
  role AS granted_role
FROM TABLE({{ db_name }}.INFORMATION_SCHEMA.DATABASE_ROLE_GRANTS())
ORDER BY grantee_name;
{% endfor %}

/*
DATABASES CREATED
=================

Created {{ data_zones | length }} database(s) for {{ data_product_name }} data product:

{%- for zone in data_zones %}
{%- set db_name = prefix ~ '_' ~ zone.name | upper %}

{{ loop.index }}. {{ db_name }}
   - Zone: {{ zone.name | upper }}
   - Purpose: {{ zone.description }}
   - Time Travel: {{ zone.time_travel_days }} days
   - Owner: {{ prefix }}_ADMIN
   - Database Roles:
     - DB_R (owned by {{ prefix }}_RBAC, granted to {{ prefix }}_READ)
     - DB_W (owned by {{ prefix }}_RBAC, granted to {{ prefix }}_WRITE)
     - DB_C (owned by {{ prefix }}_RBAC, granted to {{ prefix }}_CREATE)
{%- endfor %}

NEXT STEPS:
- Step 2.3: Create Schemas (with SC_R, SC_W, SC_C database roles)
*/
