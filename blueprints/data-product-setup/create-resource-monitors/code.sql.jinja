-- ============================================================================
-- CREATE RESOURCE MONITORS
-- ============================================================================
-- Data Product: {{ data_product_name }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: ACCOUNTADMIN (to create resource monitors)
-- ============================================================================

-- Derive the data product prefix for object names
{%- if account_strategy == 'Single Account' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set prefix = data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set prefix = data_product_name | upper %}
{%- endif %}

-- Resource monitors require ACCOUNTADMIN
USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- CREATE RESOURCE MONITOR
-- ============================================================================

CREATE RESOURCE MONITOR IF NOT EXISTS {{ prefix }}_MONITOR
  WITH
    CREDIT_QUOTA = {{ resource_monitor_credits }}
    FREQUENCY = {{ resource_monitor_frequency }}
    START_TIMESTAMP = IMMEDIATELY
    END_TIMESTAMP = NULL
    -- Notification thresholds
    TRIGGERS
      ON 50 PERCENT DO NOTIFY
      ON 75 PERCENT DO NOTIFY
      ON 90 PERCENT DO NOTIFY
      ON 100 PERCENT DO SUSPEND;

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show resource monitor
SHOW RESOURCE MONITORS LIKE '{{ prefix }}_MONITOR';

-- View monitor details
DESCRIBE RESOURCE MONITOR {{ prefix }}_MONITOR;

/*
RESOURCE MONITOR CREATED
========================

Monitor: {{ prefix }}_MONITOR
Credit Quota: {{ resource_monitor_credits }} credits
Frequency: {{ resource_monitor_frequency }}

Thresholds:
  - 50% → Notify
  - 75% → Notify
  - 90% → Notify
  - 100% → Suspend

NEXT STEPS:
- Step 5.2: Assign monitor to warehouses
- Step 5.3: Configure alert notifications
*/
