-- ============================================================================
-- CREATE WAREHOUSES
-- ============================================================================
-- Data Product: {{ data_product_name }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: {{ data_product_name | upper }}_CREATE (has CREATE WAREHOUSE privilege)
-- ============================================================================

-- Derive the data product prefix for object names
{%- if account_strategy == 'Single Account' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set prefix = data_product_domain | upper ~ '_' ~ data_product_name | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set prefix = data_product_name | upper ~ '_' ~ data_product_environment | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set prefix = data_product_name | upper %}
{%- endif %}

-- Use the CREATE role (has CREATE WAREHOUSE privilege)
USE ROLE {{ prefix }}_CREATE;

-- ============================================================================
-- CREATE WAREHOUSES
-- ============================================================================
{% for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}

-- ----------------------------------------------------------------------------
-- WAREHOUSE: {{ wh_name }}
-- ----------------------------------------------------------------------------

CREATE WAREHOUSE IF NOT EXISTS {{ wh_name }}
  WITH
    WAREHOUSE_SIZE = '{{ wh.size }}'
    MIN_CLUSTER_COUNT = {{ wh.min_cluster_count }}
    MAX_CLUSTER_COUNT = {{ wh.max_cluster_count }}
    SCALING_POLICY = 'STANDARD'
    AUTO_SUSPEND = {{ wh.auto_suspend_seconds }}
    AUTO_RESUME = TRUE
    INITIALLY_SUSPENDED = TRUE
    ENABLE_QUERY_ACCELERATION = FALSE
    COMMENT = '{{ wh.name }} warehouse for {{ data_product_name }} data product';

-- Apply governance tags
ALTER WAREHOUSE {{ wh_name }} SET TAG
    {{ platform_database_name }}.{{ governance_name }}.DOMAIN = '{{ data_product_domain }}',
    {{ platform_database_name }}.{{ governance_name }}.ENVIRONMENT = '{{ data_product_environment }}',
    {{ platform_database_name }}.{{ governance_name }}.DATAPRODUCT = '{{ data_product_name }}',
    {{ platform_database_name }}.{{ governance_name }}.WORKLOAD = '{{ wh.name | upper }}';

{% endfor %}

-- ============================================================================
-- TRANSFER OWNERSHIP TO ADMIN
-- ============================================================================

-- Switch to SECURITYADMIN to perform ownership transfer
USE ROLE SECURITYADMIN;

{% for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}
GRANT OWNERSHIP ON WAREHOUSE {{ wh_name }} TO ROLE {{ prefix }}_ADMIN COPY CURRENT GRANTS;
{% endfor %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

USE ROLE {{ prefix }}_ADMIN;

-- Show all warehouses
SHOW WAREHOUSES LIKE '{{ prefix }}_WH_%';

-- Verify tags are applied
{% for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}
SELECT SYSTEM$GET_TAG('{{ platform_database_name }}.{{ governance_name }}.DATAPRODUCT', '{{ wh_name }}', 'WAREHOUSE') AS tag_value;
{% endfor %}

/*
WAREHOUSES CREATED
==================

Created {{ warehouse_configuration | length }} warehouse(s) for {{ data_product_name }} data product:

{%- for wh in warehouse_configuration %}
{%- set wh_name = prefix ~ '_WH_' ~ wh.name | upper %}
  {{ loop.index }}. {{ wh_name }}
     Size: {{ wh.size }}
     Clusters: {{ wh.min_cluster_count }}-{{ wh.max_cluster_count }}
     Auto-suspend: {{ wh.auto_suspend_seconds }}s
{%- endfor %}

Warehouse Ownership: {{ prefix }}_ADMIN

NEXT STEPS:
- Step 3.2: Create warehouse access roles
- Step 3.3: Wire up role hierarchy
*/
